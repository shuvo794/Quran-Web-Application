{
  "number": 114,
  "name": "سُورَةُ النَّاسِ",
  "englishName": "An-Naas",
  "englishNameTranslation": "Mankind",
  "revelationType": "Meccan",
  "numberOfAyahs": 6,
  "ayats": [
    {
      "number": 6231,
      "numberInSurah": 1,
      "juz": 30,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ",
      "en": "Say, \"I seek refuge in the Lord of mankind,",
      "bn": "বলুন, আমি আশ্রয় গ্রহণ করিতেছি মানুষের পালনকর্তার,"
    },
    {
      "number": 6232,
      "numberInSurah": 2,
      "juz": 30,
      "text": "مَلِكِ ٱلنَّاسِ",
      "en": "The Sovereign of mankind.",
      "bn": "মানুষের অধিপতির,"
    },
    {
      "number": 6233,
      "numberInSurah": 3,
      "juz": 30,
      "text": "إِلَٰهِ ٱلنَّاسِ",
      "en": "The God of mankind,",
      "bn": "মানুষের মা’বুদের"
    },
    {
      "number": 6234,
      "numberInSurah": 4,
      "juz": 30,
      "text": "مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ",
      "en": "From the evil of the retreating whisperer -",
      "bn": "তার অনিষ্ট থেকে, যে কুমন্ত্রণা দেয় ও আত্নগোপন করে,"
    },
    {
      "number": 6235,
      "numberInSurah": 5,
      "juz": 30,
      "text": "ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ",
      "en": "Who whispers [evil] into the breasts of mankind -",
      "bn": "যে কুমন্ত্রণা দেয় মানুষের অন্তরে"
    },
    {
      "number": 6236,
      "numberInSurah": 6,
      "juz": 30,
      "text": "مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ",
      "en": "From among the jinn and mankind.\"",
      "bn": "জ্বিনের মধ্য থেকে অথবা মানুষের মধ্য থেকে।"
    }
  ]
}